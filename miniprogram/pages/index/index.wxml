<!--index.wxml-->
<navigation-bar title="FitTogether" back="{{false}}" color="#3730A3" background="#FFF" />

<scroll-view class="home page" id="home" scroll-y="true" enhanced="true">
  <view class="top-row">
    <view class="date">{{ today }}</view>
    <view class="plan-pill">
      <view class="plan-dot"></view>
      <text class="plan-text">{{ planLabel }} · {{ planValue }}</text>
    </view>
  </view>

  <view class="ring">
    <ring-progress
      size="{{ ringSize }}"
      stroke-width="{{ ringStrokeWidth }}"
      percent="{{ completionPercent }}"
      value="{{ consumedKcal }}"
      total="{{ targetKcal }}"
      label="已摄入"
      color="#4F46E5"
      bg-color="#E5E7EB"  
    />
  </view>

  <view class="stats">
    <view class="stat">
      <view class="stat-value stat-green">{{ remainingKcal }}</view>
      <view class="stat-label">剩余 kcal</view>
    </view>
    <view class="stat-divider" />
    <view class="stat">
      <view class="stat-value stat-orange">{{ burnedKcal }}</view>
      <view class="stat-label">运动消耗</view>
    </view>
    <view class="stat-divider" />
    <view class="stat">
      <view class="stat-value stat-indigo">{{ completionPercent }}%</view>
      <view class="stat-label">完成度</view>
    </view>
  </view>

  <view class="card-2 macros">
    <view wx:for="{{macros}}" wx:key="key" class="macro">
      <view class="macro-row">
        <text class="macro-name">{{ item.name }}</text>
        <text class="macro-value">{{ item.current }}{{ item.unit }} / {{ item.target }}{{ item.unit }}</text>
      </view>
      <progress percent="{{ item.percent }}" border-radius="6" color="{{ item.color }}" stroke-width="6" active="false"/>
    </view>
  </view>

  <view class="card-1 meal" bindtap="onTapMealPlan">
    <view class="meal-left">
      <view class="meal-title-row">
        <text class="meal-title">{{ mealPlanTitle }}</text>
        <view class="meal-badge"><text class="meal-badge-text">{{ mealPlanStatus }}</text></view>
      </view>
      <text class="meal-sub">{{ mealPlanMeals }}</text>
    </view>
    <view class="meal-right">
      <text class="meal-kcal">{{ targetKcal }} kcal</text>
      <text class="meal-arrow">›</text>
    </view>
  </view>

  <view class="card-2 actions">
    <view wx:for="{{quickActions}}" wx:key="key" class="action" data-key="{{item.key}}" bindtap="onTapQuickAction">
      <view class="action-icon"></view>
      <text class="action-title">{{ item.title }}</text>
    </view>
  </view>

  <view class="activity">
    <view class="activity-head">
      <text class="activity-title">{{ activityTitle }}</text>
      <text class="activity-more">{{ activityMore }}</text>
    </view>
    <view class="activity-list">
      <view wx:for="{{activities}}" wx:key="id" class="activity-item">
        <view class="avatar"><text class="avatar-text">{{ item.initial }}</text></view>
        <view class="activity-content">
          <text class="activity-text">{{ item.name }} {{ item.action }}</text>
        </view>
        <text class="activity-time">{{ item.time }}</text>
      </view>
    </view>
  </view>
</scroll-view>

<custom-tab-bar />
