<!--pages/plan.wxml-->
<navigation-bar title="计划" back="{{false}}" color="#111827" background="#FFF" />

<view class="plan page" id="plan">
  <view class="header">
    <segment-control options="{{segments}}" value="{{segment}}" bind:change="onSegmentChange" />
  </view>

  <view class="content">
    <view wx:if="{{segment === '方案搭配'}}" class="meal-root">
      
      <!-- Multiple Plans Selector -->
      <scroll-view scroll-x="true" class="plan-tabs" show-scrollbar="false">
        <view class="plan-tabs-inner">
          <view 
            wx:for="{{mealPlans}}" 
            wx:key="id" 
            class="plan-tab {{index === activePlanIndex ? 'active' : ''}}"
            data-index="{{index}}"
            bindtap="onSwitchPlan"
          >
            {{item.name}}
          </view>
          <view class="plan-tab-add" bindtap="onAddPlan">+ 新建套餐</view>
        </view>
      </scroll-view>

      <view class="meal-info card-2">
        <view class="meal-info-left">
          <view class="tag" style="border-color: {{colors.success}};">
            <text class="tag-text" style="color: {{colors.success}};">{{mealPlans[activePlanIndex].name}}</text>
          </view>
        </view>
        <text class="meal-info-right">目标热量 2480kcal</text>
      </view>

      <view wx:for="{{mealCards}}" wx:key="section" wx:for-item="card" class="meal-card card-1">
        <view class="meal-card-head">
          <view class="meal-card-title">{{card.section}}</view>
          <view class="meal-card-add" bindtap="onTapAddMealItem" data-section="{{card.section}}">
            <text class="meal-card-add-plus" style="color: {{colors.primary}};">＋</text>
            <text class="meal-card-add-text" style="color: {{colors.primary}};">添加</text>
          </view>
        </view>

        <view wx:for="{{card.items}}" wx:key="food" wx:for-item="food" class="meal-item">
          <view class="meal-item-left">
            <text class="meal-item-food">{{food.food}}</text>
            <text class="meal-item-grams">{{food.grams}}</text>
          </view>
          <view class="meal-item-right">
            <text class="meal-item-kcal">{{food.kcal}}</text>
            <view
              class="meal-item-trash"
              bindtap="onRemoveMealItem"
              data-section="{{card.section}}"
              data-index="{{index}}"
            >
              <text class="meal-item-trash-icon">🗑</text>
            </view>
          </view>
        </view>
        <view wx:if="{{card.items.length === 0}}" class="meal-item-empty" style="text-align: center; color: #9CA3AF; font-size: 13px; padding: 12px 0;">
          {{auth.isLoggedIn ? '暂无饮食安排' : '登录后生成个性化排餐'}}
        </view>

        <view class="meal-card-foot">
          <text class="meal-card-total">小计 {{card.totalKcal}} kcal</text>
        </view>
      </view>

      <view class="ai-fab" bindtap="onOpenAIDrawer">
        <text class="ai-fab-icon" style="color: {{colors.primary}};">✨</text>
      </view>

      <view class="nutrition-bar">
        <view class="nutrition-left">
          <view wx:for="{{nutritionSummary}}" wx:key="label" class="nutrition-item">
            <view class="nutrition-label">{{item.label}}</view>
            <view class="nutrition-value" style="color: {{item.color}};">{{item.value}}</view>
          </view>
        </view>
        <view class="nutrition-right">
          <view class="nutrition-total-label">总热量</view>
          <view class="nutrition-total" style="color: {{mealTotalKcal >= 2400 ? colors.success : colors.secondary}};">
            {{mealTotalKcal}}
            <text class="nutrition-unit">kcal</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{segment === '日历排餐'}}">
      <view class="calendar-tabs">
        <view class="calendar-tab {{calendarView === 'week' ? 'active' : ''}}" bindtap="onChangeCalendarView" data-view="week">周视图</view>
        <view class="calendar-tab {{calendarView === 'month' ? 'active' : ''}}" bindtap="onChangeCalendarView" data-view="month">月视图</view>
      </view>

      <swiper class="calendar-swiper" current="{{calendarView === 'week' ? 0 : 1}}" bindchange="onSwiperChange">
        <swiper-item>
          <view class="week-nav">
            <view class="week-btn" bindtap="onPrevWeek">
              <text class="week-btn-icon" style="color: {{colors.primary}};">‹</text>
              <text class="week-btn-text" style="color: {{colors.primary}};">上周</text>
            </view>

            <view class="week-center">
              <view class="week-title">{{calendarWeekTitle}}</view>
              <view class="week-range">{{calendarWeekRange}}</view>
            </view>

            <view class="week-right">
              <view class="week-copy" bindtap="onCopyPrevWeek">复制上周</view>
              <view class="week-btn" bindtap="onNextWeek">
                <text class="week-btn-text" style="color: {{colors.primary}};">下周</text>
                <text class="week-btn-icon" style="color: {{colors.primary}};">›</text>
              </view>
            </view>
          </view>

          <view wx:if="{{auth.isLoggedIn}}" class="calendar-grid">
            <view
              wx:for="{{calendarDays}}"
              wx:key="day"
              class="calendar-cell"
              bindtap="onOpenPlanPicker"
              data-day="{{item.day}}"
              style="border-color: {{item.isToday ? colors.primary : 'transparent'}};"
            >
              <view class="calendar-day">{{item.day}} {{item.isToday ? '· 今' : ''}}</view>
              <view class="calendar-plan {{item.planName ? 'has-plan' : ''}}">{{item.planName || '去排餐 ›'}}</view>
            </view>
          </view>
          <view wx:else class="empty-state">
            <view class="lottie-mock"></view>
            <view class="empty-text">开启专属你的科学饮食计划</view>
            <view class="empty-btn primary">立即创建</view>
          </view>
        </swiper-item>

        <swiper-item>
          <view class="month-grid">
            <view class="month-header">
              <text>一</text><text>二</text><text>三</text><text>四</text><text>五</text><text>六</text><text>日</text>
            </view>
            <view class="month-body">
              <view
                wx:for="{{calendarMonthDays}}"
                wx:key="index"
                class="month-cell"
              >
                <view class="month-day {{item.isToday ? 'today' : ''}}" style="background: {{item.isToday ? colors.primary : 'transparent'}}; color: {{item.isToday ? '#fff' : '#111827'}};">{{item.day}}</view>
                <view wx:if="{{item.planName}}" class="month-plan plan-tag" style="background: {{colors.primaryBg}}; color: {{colors.primary}};">
                  {{item.planName}}
                </view>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>
  </view>

  <view wx:if="{{showPlanPicker}}" class="overlay">
    <view class="overlay-backdrop" catchtap="onClosePlanPicker"></view>
    <view class="drawer" catchtap="noop">
      <view class="drawer-grabber"></view>
      <view class="picker-head">
        <view class="picker-title">选择{{pickerDay}}套餐</view>
      </view>
      <scroll-view class="drawer-scroll" scroll-y="true" enhanced="true">
        <view
          class="plan-option"
          data-planid=""
          bindtap="onSelectPlan"
        >
          <view class="plan-option-left">
            <view class="plan-option-name" style="color: #9CA3AF;">清除排餐</view>
          </view>
        </view>
        <view
          wx:for="{{mealPlans}}"
          wx:key="id"
          class="plan-option"
          data-planid="{{item.id}}"
          bindtap="onSelectPlan"
        >
          <view class="plan-option-left">
            <view class="plan-option-name">{{item.name}}</view>
          </view>
          <view class="plan-option-right">
            <text wx:if="{{pickerSelectedPlanId === item.id}}" class="plan-option-check" style="color: {{colors.success}};">✓</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>

<custom-tab-bar />
