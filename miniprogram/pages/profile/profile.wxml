<navigation-bar title="我的" back="{{false}}" color="#111827" background="#fff" />

<scroll-view class="profile page" scroll-y="true" enhanced="true">
  <view class="profile-header">
    <view class="user-row">
      <view class="avatar-wrap">
        <image class="avatar" src="{{user.avatarUrl}}" mode="aspectFill" />
        <view wx:if="{{profileComplete}}" class="online-dot">
          <text class="online-check">✓</text>
        </view>
      </view>

      <view class="user-info">
        <view class="user-name">{{user.name}}</view>
        <view class="user-sub">
          训练第 <text class="user-sub-strong">{{user.trainingDays}}</text> 天
        </view>
      </view>

      <view class="stats-row">
        <view class="stat-card">
          <view class="stat-value">{{stats.bmi}}</view>
          <view class="stat-label">BMI</view>
        </view>
        <view class="stat-card">
          <view class="stat-value">{{stats.weekCheckins}}</view>
          <view class="stat-label">本周打卡</view>
        </view>
      </view>
    </view>

    <view class="progress-row">
      <view wx:for="{{progressStats}}" wx:key="label" class="progress-cell">
        <view class="progress-value" style="color: {{item.color}};">{{item.value}}</view>
        <view class="progress-label">{{item.label}}</view>
      </view>
    </view>

    <view wx:if="{{showLoginPrompt}}" class="login-card">
      <view class="login-title">登录后同步数据</view>
      <view class="login-sub">跨设备备份 · 解锁训练小队/情侣模式</view>
      <view class="login-actions">
        <view class="login-btn primary" bindtap="onTapLogin">去登录</view>
        <view class="login-btn" bindtap="onTapSkipLogin">先逛逛</view>
      </view>
    </view>

    <view wx:if="{{!profileComplete}}" class="profile-tip">
      <view class="profile-tip-left">
        <view class="profile-tip-title">完善资料，解锁更精准推荐</view>
        <view class="profile-tip-sub">{{auth.isLoggedIn ? '保存到账号，随时同步' : '未登录也可先填写，登录后可同步'}}</view>
      </view>
      <view class="profile-tip-btn" bindtap="onTapStartProfile">去填写</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">本周打卡</view>
    <view class="week-card">
      <view wx:for="{{weekDays}}" wx:key="day" class="week-item">
        <view
          class="week-dot"
          style="background: {{item.done ? (item.isToday ? colors.primary : colors.success) : colors.bg2}}; border: {{item.isToday ? ('2px solid ' + colors.primary) : 'none'}};"
        >
          <text class="week-dot-text" style="color: {{ item.done ? '#FFFFFF' : colors.text3 }};">
            {{item.done ? '✓' : '—'}}
          </text>
        </view>
        <text class="week-label" style="color: {{ item.isToday ? colors.primary : colors.text3 }};">周{{item.day}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="menu-card">
      <view
        wx:for="{{menuItems}}"
        wx:key="id"
        class="menu-item {{index < menuItems.length - 1 ? 'menu-item-border' : ''}}"
        data-id="{{item.id}}"
        bindtap="onTapMenuItem"
      >
        <view class="menu-icon" style="background: {{item.iconBg}};">
          <text class="menu-icon-text" style="color: {{item.iconColor}};">{{item.iconText}}</text>
        </view>

        <view class="menu-text">
          <view class="menu-title">{{item.title}}</view>
          <view class="menu-subtitle">{{item.subtitle}}</view>
        </view>

        <view class="menu-right">
          <view wx:if="{{item.badge}}" class="menu-badge">
            <text class="menu-badge-text">{{item.badge}}</text>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{auth.isLoggedIn}}" class="section logout-section">
    <button class="logout-btn" bindtap="onTapLogout">退出登录</button>
  </view>

  <view wx:if="{{showProfileForm}}" class="overlay">
    <view class="overlay-backdrop" catchtap="onCloseProfileForm"></view>
    <view class="drawer" catchtap="noop">
      <view class="drawer-grabber"></view>
      <view class="form-head">
        <view class="form-title">完善资料</view>
        <view class="form-desc">{{auth.isLoggedIn ? '将保存到账号' : '将保存到本地草稿'}}</view>
      </view>

      <view class="form-body">
        <view class="form-field">
          <view class="form-label">身高</view>
          <view class="form-input-row">
            <input class="form-input" type="digit" value="{{form.heightCm}}" data-field="heightCm" bindinput="onFormInput" placeholder="例如 175" />
            <text class="form-unit">cm</text>
          </view>
        </view>

        <view class="form-field">
          <view class="form-label">当前体重</view>
          <view class="form-input-row">
            <input class="form-input" type="digit" value="{{form.weightKg}}" data-field="weightKg" bindinput="onFormInput" placeholder="例如 71.0" />
            <text class="form-unit">kg</text>
          </view>
        </view>

        <view class="form-field">
          <view class="form-label">目标体重</view>
          <view class="form-input-row">
            <input class="form-input" type="digit" value="{{form.targetWeightKg}}" data-field="targetWeightKg" bindinput="onFormInput" placeholder="例如 68.0" />
            <text class="form-unit">kg</text>
          </view>
        </view>

        <view class="form-field">
          <view class="form-label">目标</view>
          <picker mode="selector" range="{{goalOptions}}" value="{{form.goalIndex}}" bindchange="onGoalChange">
            <view class="picker-box">
              <text class="picker-text">{{goalOptions[form.goalIndex]}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="form-actions">
        <view class="form-btn primary" bindtap="onTapSaveProfile">保存</view>
        <view class="form-btn ghost" bindtap="onCloseProfileForm">先不填</view>
      </view>
    </view>
  </view>
</scroll-view>

<custom-tab-bar />
