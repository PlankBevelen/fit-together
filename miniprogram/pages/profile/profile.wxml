<navigation-bar title="我的" back="{{false}}" color="#111827" background="#fff" />

<view class="profile page">
  <view class="profile-header">
    <view wx:if="{{!auth.isLoggedIn}}" class="login-banner-container">
      <view wx:if="{{showLoginPrompt}}" class="login-banner">
        <view class="login-banner-content">
          <view class="login-banner-title">登录解锁完整体验</view>
          <view class="login-banner-sub">跨设备备份 · 训练小队 · 情侣模式</view>
        </view>
        <view class="login-banner-actions">
          <view class="login-banner-btn primary" bindtap="onTapLogin">登录 / 注册</view>
          <view class="login-banner-close" bindtap="onTapSkipLogin">×</view>
        </view>
      </view>
      <view wx:else class="login-banner-collapsed" bindtap="onRecallLoginPrompt">
        <text class="login-banner-collapsed-text">登录 / 注册</text>
        <text class="login-banner-collapsed-icon">›</text>
      </view>
    </view>

    <view class="user-card" bindtap="onTapUserHeader">
      <view class="user-row">
        <view class="avatar-wrap" hover-class="avatar-hover" hover-stay-time="100">
          <image class="avatar" src="{{user.avatarUrl}}" mode="aspectFill" />
          <view wx:if="{{profileComplete}}" class="online-dot">
            <text class="online-check">✓</text>
          </view>
        </view>

        <view class="user-info">
          <view class="user-name">{{user.name}}</view>
          <view class="user-sub">
            训练第 <text class="user-sub-strong">{{user.trainingDays}}</text> 天
          </view>
        </view>
        
        <view class="user-arrow">›</view>
      </view>

      <view class="stats-row">
        <view class="stat-card">
          <view class="stat-value">{{stats.bmi}}</view>
          <view class="stat-label">BMI</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-card">
          <view class="stat-value">{{stats.weekCheckins}}</view>
          <view class="stat-label">本周打卡</view>
        </view>
      </view>
    </view>

    <view wx:if="{{!profileComplete}}" class="profile-tip">
      <view class="profile-tip-left">
        <view class="profile-tip-title">完善资料，解锁更精准推荐</view>
        <view class="profile-tip-sub">{{auth.isLoggedIn ? '保存到账号，随时同步' : '未登录也可先填写，登录后可同步'}}</view>
      </view>
      <view class="profile-tip-btn" bindtap="onTapStartProfile">去填写</view>
    </view>
  </view>

  <view class="list-section">
    <view class="list">
      <view class="list-item" bindtap="onTapProfile">
        <view class="list-item__bd">个人资料</view>
        <view class="list-item__ft">
          <text class="list-item__arrow">›</text>
        </view>
      </view>

      <view class="list-item" bindtap="onTapCouple">
        <view class="list-item__bd">情侣模式</view>
        <view class="list-item__ft">
          <text class="list-item__arrow">›</text>
        </view>
      </view>

      <view class="list-item" bindtap="onTapSquad">
        <view class="list-item__bd">训练小队</view>
        <view class="list-item__ft">
          <text class="list-item__arrow">›</text>
        </view>
      </view>

      <view class="list-item" open-type="feedback" plain="true">
        <view class="list-item__bd">意见反馈</view>
        <view class="list-item__ft">
          <text class="list-item__arrow">›</text>
        </view>
      </view>

      <view class="list-item" bindtap="onTapSettings">
        <view class="list-item__bd">设置</view>
        <view class="list-item__ft">
          <text class="list-item__arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Login Sheet -->
  <view wx:if="{{showLoginSheet}}" class="login-sheet-overlay" style="pointer-events: none;">
    <view class="login-sheet" style="pointer-events: auto;">
      <view class="login-sheet-grabber"></view>
      <view class="login-sheet-head">
        <view class="login-sheet-title">需登录后使用</view>
        <view class="login-sheet-close" bindtap="onCloseLoginSheet">×</view>
      </view>
      <view class="login-sheet-body">
        <text class="login-sheet-desc">登录后可同步数据，并解锁训练小队/情侣模式等功能。</text>
        <view class="login-sheet-actions">
          <view class="login-sheet-btn primary" bindtap="onTapLogin">去登录</view>
          <view class="login-sheet-btn ghost" bindtap="onCloseLoginSheet">稍后再说</view>
        </view>
      </view>
    </view>
  </view>
</view>

<custom-tab-bar />
